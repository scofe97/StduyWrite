# 좋은 예시: 캐시 최적화된 Dockerfile
FROM node:20-alpine

WORKDIR /app

# 1. 의존성 파일만 먼저 복사
COPY package*.json ./

# 2. 의존성 설치 (package.json 변경 시에만 재실행)
RUN npm ci --only=production

# 3. 소스 코드 복사 (자주 변경됨)
COPY . .

# 4. 불필요한 파일 제외 (.dockerignore 사용 권장)
RUN rm -rf node_modules/.cache

EXPOSE 3000

CMD ["node", "app.js"]
