// =============================================================================
// Declarative Pipeline: sample-app CI/CD
//
// 이 Jenkinsfile은 Go 애플리케이션의 빌드-테스트-배포 파이프라인을 정의한다.
// TODO가 표시된 부분을 직접 구현하면서 Jenkins Pipeline 문법을 학습한다.
// =============================================================================

pipeline {
    agent {
        label 'docker'  // docker 레이블이 붙은 Agent에서 실행
    }

    environment {
        APP_NAME    = 'sample-app'
        REGISTRY    = 'localhost:5000'
        IMAGE_NAME  = "${REGISTRY}/${APP_NAME}"
        IMAGE_TAG   = "${BUILD_NUMBER}"
    }

    options {
        timeout(time: 15, unit: 'MINUTES')  // 전체 파이프라인 타임아웃
        timestamps()                         // 로그에 타임스탬프 출력
        disableConcurrentBuilds()            // 동시 빌드 방지
    }

    stages {
        // -----------------------------------------------------------------
        // Stage 1: Checkout
        // SCM에서 소스코드를 가져온다.
        // -----------------------------------------------------------------
        stage('Checkout') {
            steps {
                // TODO: SCM에서 소스코드를 체크아웃하라
                // 힌트: checkout scm 또는 git url: '...' 사용
                echo 'TODO: 소스코드 체크아웃 구현'
            }
        }

        // -----------------------------------------------------------------
        // Stage 2: Build
        // Go 애플리케이션을 컴파일한다.
        // -----------------------------------------------------------------
        stage('Build') {
            steps {
                // TODO: Docker 컨테이너 안에서 Go 빌드를 실행하라
                // 힌트: docker.image('golang:1.22-alpine').inside { sh '...' }
                // 질문: 왜 호스트에 Go를 설치하지 않고 Docker를 사용하는가?
                echo 'TODO: Go 애플리케이션 빌드 구현'
            }
        }

        // -----------------------------------------------------------------
        // Stage 3: Test
        // 단위 테스트를 실행한다.
        // -----------------------------------------------------------------
        stage('Test') {
            steps {
                // TODO: Go 테스트를 실행하라
                // 힌트: sh 'go test ./... -v -coverprofile=coverage.out'
                // 보너스: JUnit 형식으로 테스트 결과를 변환하여 Jenkins에 표시
                echo 'TODO: 테스트 실행 구현'
            }
            post {
                always {
                    // TODO: 테스트 결과 리포트를 아카이브하라
                    // 힌트: junit 'test-results.xml'
                    echo 'TODO: 테스트 결과 리포트 수집'
                }
            }
        }

        // -----------------------------------------------------------------
        // Stage 4: Docker Build
        // 애플리케이션을 Docker 이미지로 빌드한다.
        // -----------------------------------------------------------------
        stage('Docker Build') {
            steps {
                // TODO: Dockerfile을 사용하여 Docker 이미지를 빌드하라
                // 힌트: docker.build("${IMAGE_NAME}:${IMAGE_TAG}", "./sample-app")
                // 질문: 멀티스테이지 빌드가 이미지 크기에 어떤 영향을 주는가?
                echo 'TODO: Docker 이미지 빌드 구현'
            }
        }

        // -----------------------------------------------------------------
        // Stage 5: Docker Push
        // 빌드된 이미지를 Registry에 push한다.
        // -----------------------------------------------------------------
        stage('Docker Push') {
            steps {
                // TODO: 빌드된 이미지를 로컬 Registry에 push하라
                // 힌트: docker.withRegistry("http://${REGISTRY}") { image.push("${IMAGE_TAG}"); image.push("latest") }
                // 질문: latest 태그와 빌드 번호 태그를 둘 다 push하는 이유는?
                echo 'TODO: Docker 이미지 push 구현'
            }
        }

        // -----------------------------------------------------------------
        // Stage 6: Deploy
        // 이미지를 배포 대상 환경에 배포한다.
        // -----------------------------------------------------------------
        stage('Deploy') {
            steps {
                // TODO: 빌드된 이미지를 배포하라
                // 옵션 A (Docker): sh "docker run -d --name ${APP_NAME} -p 8081:8081 ${IMAGE_NAME}:${IMAGE_TAG}"
                // 옵션 B (K8s):   sh "kubectl set image deployment/${APP_NAME} ${APP_NAME}=${IMAGE_NAME}:${IMAGE_TAG}"
                // 질문: 배포 전 기존 컨테이너를 어떻게 정리해야 하는가?
                echo 'TODO: 배포 구현'
            }
        }
    }

    // =====================================================================
    // Post Actions: 파이프라인 완료 후 항상 실행되는 작업
    // =====================================================================
    post {
        always {
            // TODO: 빌드 워크스페이스를 정리하라
            // 힌트: cleanWs()
            echo '파이프라인 완료 — 워크스페이스 정리'
        }
        success {
            // TODO: 성공 알림을 보내라 (Slack, 이메일 등)
            // 힌트: slackSend channel: '#ci', message: "빌드 성공: ${env.JOB_NAME} #${env.BUILD_NUMBER}"
            echo "빌드 성공: ${env.JOB_NAME} #${env.BUILD_NUMBER}"
        }
        failure {
            // TODO: 실패 알림을 보내라
            // 힌트: slackSend color: 'danger', message: "빌드 실패: ${env.JOB_NAME} #${env.BUILD_NUMBER}"
            echo "빌드 실패: ${env.JOB_NAME} #${env.BUILD_NUMBER}"
        }
    }
}
